# Configuration pour le développement local
# Copiez ce fichier vers .env et remplissez les valeurs

# Clé API Groq (obligatoire)
GROQ_API_KEY=votre_cle_api_groq_ici

# Configuration base de données locale
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=transpobot
DB_PORT=3306

# Pour Railway, seules GROQ_API_KEY et DATABASE_URL sont nécessaires
# DATABASE_URL sera automatiquement fournie par Railway